{
  "info": {
    "_postman_id": "49339361-a5d1-44d3-a641-3b13e314b97b",
    "name": "LMS Auth - Complete Flow",
    "description": "Chạy bằng Collection Runner với environment LMS Local. NODE_ENV phải khác production để verificationToken/resetToken xuất hiện trong response phục vụ test local.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Register student",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const suffix = Date.now().toString().slice(-10);",
              "pm.environment.set('authEmail', `student${suffix}@example.com`);",
              "pm.environment.set('authUsername', `student${suffix}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "const body = pm.response.json();",
              "pm.expect(body.user.role).to.eql('student');",
              "pm.expect(body.user.isVerified).to.eql(false);",
              "pm.expect(body).to.have.property('verificationToken');",
              "pm.environment.set('authUserId', body.user.id);",
              "pm.environment.set('verificationToken', body.verificationToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{authUsername}}\",\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/api/auth/register"
      }
    },
    {
      "name": "2. Verify email",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.expect(pm.response.json().user.isVerified).to.eql(true);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{verificationToken}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/api/auth/verify-email"
      }
    },
    {
      "name": "3. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.expect(body).to.have.property('accessToken');",
              "pm.environment.set('studentToken', body.accessToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "4. Get own profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.expect(pm.response.json()._id).to.eql(pm.environment.get('authUserId'));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
        "url": "{{baseUrl}}/api/users/me"
      }
    },
    {
      "name": "5. Rotate refresh token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.expect(body).to.have.property('accessToken');",
              "pm.environment.set('studentToken', body.accessToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
        "url": "{{baseUrl}}/api/auth/refresh"
      }
    },
    {
      "name": "6. Forgot password",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.expect(body).to.have.property('resetToken');",
              "pm.environment.set('resetToken', body.resetToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{authEmail}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/api/auth/forgot-password"
      }
    },
    {
      "name": "7. Reset password",
      "event": [
        {
          "listen": "test",
          "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));"] }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"{{authNewPassword}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/api/auth/reset-password"
      }
    },
    {
      "name": "8. Login with new password",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.environment.set('studentToken', pm.response.json().accessToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authNewPassword}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "9. Logout",
      "event": [
        {
          "listen": "test",
          "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));"] }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } },
        "url": "{{baseUrl}}/api/auth/logout"
      }
    },
    {
      "name": "10. Cleanup test user",
      "event": [
        {
          "listen": "test",
          "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));"] }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }],
        "url": "{{baseUrl}}/api/users/{{authUserId}}"
      }
    }
  ]
}
