{
  "info": {
    "_postman_id": "7ba94af9-6743-47da-b32b-fbcf3c35f824",
    "name": "LMS API - End-to-End Flow",
    "description": "Chạy bằng Collection Runner theo thứ tự. Cần điền adminToken, teacherToken, teacher2Token và studentToken trong environment trước khi chạy.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Main flow",
      "item": [
        {
          "name": "1. Admin creates category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Node.js {{$timestamp}}\",\n  \"description\": \"Category generated by Postman\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/categories"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.expect(body).to.have.property('_id');",
                  "pm.expect(body).to.have.property('slug');",
                  "pm.environment.set('categoryId', body._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Teacher creates draft course",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Express.js {{$timestamp}}\",\n  \"description\": \"Khoa hoc xay dung REST API voi Express\",\n  \"category\": \"{{categoryId}}\",\n  \"price\": 100000\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/courses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.expect(body.isPublished).to.eql(false);",
                  "pm.expect(body.category).to.eql(pm.environment.get('categoryId'));",
                  "pm.environment.set('courseId', body._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Public list hides draft",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/courses?page=1&limit=10"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "const ids = body.courses.map(course => course._id);",
                  "pm.test('Draft is not public', () => pm.expect(ids).not.to.include(pm.environment.get('courseId')));",
                  "pm.expect(body.pagination).to.have.property('total');"
                ]
              }
            }
          ]
        },
        {
          "name": "4. Teacher sees own draft",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/api/courses/my/courses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const ids = pm.response.json().map(course => course._id);",
                  "pm.test('Own draft is returned', () => pm.expect(ids).to.include(pm.environment.get('courseId')));"
                ]
              }
            }
          ]
        },
        {
          "name": "5. Teacher creates lesson order 2",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Lesson order 2\",\n  \"content\": \"Second lesson\",\n  \"videoUrl\": \"https://example.com/video-2.mp4\",\n  \"order\": 2\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/courses/{{courseId}}/lessons"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.environment.set('lesson2Id', pm.response.json()._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "6. Teacher creates lesson order 1",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Lesson order 1\",\n  \"content\": \"First lesson\",\n  \"videoUrl\": \"https://example.com/video-1.mp4\",\n  \"order\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/courses/{{courseId}}/lessons"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.environment.set('lessonId', pm.response.json()._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "7. Lessons are sorted by order",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/api/courses/{{courseId}}/lessons"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const lessons = pm.response.json();",
                  "pm.test('Lessons are ascending', () => {",
                  "  for (let i = 1; i < lessons.length; i++) pm.expect(lessons[i - 1].order).to.be.at.most(lessons[i].order);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "8. Teacher publishes course",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isPublished\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/courses/{{courseId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.expect(pm.response.json().isPublished).to.eql(true);"
                ]
              }
            }
          ]
        },
        {
          "name": "9. Public list contains published course",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/courses?category={{categoryId}}&page=1&limit=100"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const ids = pm.response.json().courses.map(course => course._id);",
                  "pm.test('Published course is public', () => pm.expect(ids).to.include(pm.environment.get('courseId')));"
                ]
              }
            }
          ]
        },
        {
          "name": "10. Student enrolls in course",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/api/courses/{{courseId}}/enrollments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.environment.set('enrollmentId', pm.response.json()._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "11. Student creates comment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Bai hoc rat de hieu {{$timestamp}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/lessons/{{lessonId}}/comments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.expect(body).to.have.property('user');",
                  "pm.environment.set('commentId', body._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "12. Student updates own comment",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Comment da chinh sua\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/lessons/{{lessonId}}/comments/{{commentId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.expect(pm.response.json().content).to.eql('Comment da chinh sua');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Authentication, validation and RBAC",
      "item": [
        {
          "name": "Protected request without token returns 401",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Unauthorized course\",\n  \"description\": \"This request must be rejected\",\n  \"category\": \"{{categoryId}}\",\n  \"price\": 0\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/courses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401', () => pm.response.to.have.status(401));",
                  "pm.expect(pm.response.json().message).to.eql('No token');"
                ]
              }
            }
          ]
        },
        {
          "name": "Student cannot create category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Forbidden {{$timestamp}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/categories"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403', () => pm.response.to.have.status(403));",
                  "pm.expect(pm.response.json().message).to.eql('Forbidden');"
                ]
              }
            }
          ]
        },
        {
          "name": "Invalid course body returns 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"A\",\n  \"description\": \"short\",\n  \"category\": \"bad-id\",\n  \"price\": -1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/courses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                  "pm.expect(pm.response.json()).to.have.property('message');"
                ]
              }
            }
          ]
        },
        {
          "name": "Teacher 2 cannot update Teacher 1 course",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacher2Token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Unauthorized update\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/courses/{{courseId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "Empty comment returns 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/lessons/{{lessonId}}/comments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 - Users",
      "item": [
        {
          "name": "Student gets own profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/api/users/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.expect(body).not.to.have.property('password');",
                  "pm.expect(body).not.to.have.property('refreshToken');",
                  "pm.environment.set('studentId', body._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Student cannot list users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/api/users?page=1&limit=10"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin lists users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/api/users?page=1&limit=10&role=student"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.expect(body).to.have.property('users');",
                  "pm.expect(body).to.have.property('pagination');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04 - Cleanup",
      "item": [
        {
          "name": "Student deletes own comment",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/api/lessons/{{lessonId}}/comments/{{commentId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Teacher deletes lesson order 1",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/api/courses/{{courseId}}/lessons/{{lessonId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        },
        {
          "name": "Teacher deletes lesson order 2",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/api/courses/{{courseId}}/lessons/{{lesson2Id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        },
        {
          "name": "Teacher deletes course",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/api/courses/{{courseId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        },
        {
          "name": "Admin deletes category",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/api/categories/{{categoryId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status is 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        }
      ]
    }
  ],
  "variable": []
}
