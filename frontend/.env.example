# Local: để trống để Vite proxy /api sang http://localhost:3000.
# Production: URL gốc của backend đã deploy, không thêm dấu / cuối.
VITE_API_URL=https://your-backend-domain.onrender.com

# Google Web Client ID. Phải trùng GOOGLE_CLIENT_ID ở backend.
# Secret chỉ đặt ở backend bằng GOOGLE_CLIENT_SECRET, không đặt ở frontend.
VITE_GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
